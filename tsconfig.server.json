{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",              // 关键：使用 CommonJS 模块，避免扩展名问题
    "outDir": "dist-server",           // 编译输出到 dist-server
    "rootDir": "server",               // 源文件根目录设为 server
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/**/*.ts"],       // 包含 server 下所有 ts 文件
  "exclude": ["node_modules", "dist-server"]
}
